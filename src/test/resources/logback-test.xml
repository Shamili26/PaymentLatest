<?xml version="1.0" encoding="UTF-8"?>
<!--
    Test-only logging configuration.

    Logback automatically picks up "logback-test.xml" ahead of "logback-spring.xml"
    when it is on the test classpath, so unit/integration tests log ONLY to the
    console and never create local log files.
-->
<configuration>

    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <logger name="com.paymentapp" level="DEBUG"/>

</configuration>

