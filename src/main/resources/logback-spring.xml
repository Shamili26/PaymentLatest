<?xml version="1.0" encoding="UTF-8"?>
<!--
    Logback configuration for the Payment App backend.

    Writes logs to BOTH the console and rolling local files.
    Works the same on Windows (dev) and on a Linux server.

    The log directory is resolved in this order of precedence:
      1. The "LOG_PATH" environment variable        (e.g. export LOG_PATH=/var/log/payment-app)
      2. The "log.path" system / Spring property     (e.g. -Dlog.path=/var/log/payment-app)
      3. Default: a "logs" folder under the app's working directory  (./logs)

    Override examples:
      Linux  :  java -jar app.jar  with arg  log.path=/var/log/payment-app
      Linux  :  LOG_PATH=/var/log/payment-app java -jar app.jar
      Windows:  java -jar app.jar  with arg  log.path=C:/payment-app/logs
-->
<configuration>

    <!-- Pull Spring's default colour/pattern helpers in. -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- Resolve the log directory and base file name (with safe defaults). -->
    <property name="LOG_PATH" value="${LOG_PATH:-${log.path:-logs}}"/>
    <property name="LOG_FILE_NAME" value="${log.file.name:-payment-app}"/>

    <!-- Plain (non-coloured) pattern for files; coloured pattern for console. -->
    <property name="FILE_LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"/>
    <property name="CONSOLE_LOG_PATTERN"
              value="%clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr(%-5level) %clr(%logger{36}){cyan} %clr(-){faint} %msg%n"/>

    <!-- ── Console appender (handy during local development) ───────────────── -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ── Rolling file appender (all application logs) ────────────────────── -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${LOG_FILE_NAME}.log</file>
        <encoder>
            <pattern>${FILE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <!-- Roll daily AND when a file passes 10MB; keep 30 days, cap total at 1GB. -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${LOG_FILE_NAME}-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- ── Separate rolling file appender for ERROR-level logs only ────────── -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${LOG_FILE_NAME}-error.log</file>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <encoder>
            <pattern>${FILE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${LOG_FILE_NAME}-error-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- ── Async wrappers keep logging off the request thread ──────────────── -->
    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="FILE"/>
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
    </appender>

    <!-- ── JSON appender (ELK / Grafana Loki friendly) ─────────────────────── -->
    <appender name="JSON_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${LOG_FILE_NAME}.json</file>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <timeZone>UTC</timeZone>
            <includeMdcKeyName>true</includeMdcKeyName>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${LOG_FILE_NAME}-%d{yyyy-MM-dd}.%i.json.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!--
        Default profile: human-readable console + plain-text rolling files.
        Active unless the "json" Spring profile is enabled.
    -->
    <springProfile name="!json">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>
    </springProfile>

   <!--
    JSON profile: structured logs to file (and console as JSON too).
    Enable with:  -spring.profiles.active=json   (or SPRING_PROFILES_ACTIVE=json)
    -->
    <springProfile name="json">
        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <timeZone>UTC</timeZone>
                <includeMdcKeyName>true</includeMdcKeyName>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE"/>
            <appender-ref ref="JSON_FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>
    </springProfile>

    <!-- Application packages can stay more verbose if desired. -->
    <logger name="com.paymentapp" level="DEBUG"/>

</configuration>
