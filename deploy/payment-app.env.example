# =============================================================================
#  Environment overrides for the Payment App backend.
#
#  Install:
#    sudo mkdir -p /etc/payment-app
#    sudo cp deploy/payment-app.env.example /etc/payment-app/payment-app.env
#    sudo chmod 600 /etc/payment-app/payment-app.env   # protect secrets
#
#  Then enable it in payment-app.service by uncommenting:
#    EnvironmentFile=-/etc/payment-app/payment-app.env
#
#  Spring Boot maps these UPPER_SNAKE_CASE vars onto its properties automatically.
# =============================================================================

# Where log files are written (read by logback-spring.xml)
LOG_PATH=/var/log/payment-app

# Emit structured JSON logs (uncomment for ELK / Grafana Loki)
# SPRING_PROFILES_ACTIVE=json

# Database connection
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/paymentdb
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=admin

# JWT signing secret (base64). CHANGE THIS in production.
APP_JWT_SECRET=change-me-to-a-long-random-base64-secret

# CORS — your frontend origin(s)
APP_CORS_ALLOWED_ORIGINS=https://your-frontend.example.com

